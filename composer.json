{
    "name": "ytgov/lagoon-healthandwellnessyukon-ca",
    "description": "Health and Wellness Yukon - Health Authority",
    "type": "project",
    "license": "MIT",
    "repositories": [
        {
            "type": "composer",
            "url": "https://packages.drupal.org/8"
        },
        {
            "type": "vcs",
            "url": "git@github.com:ytgov/lagoon-boutique-base-image.git"
        },
        {
            "type": "composer",
            "url": "https://asset-packagist.org"
        }
    ],
    "require": {
        "ytgov/lagoon-boutique-base-image": "dev-prod",
        "drupal/bootstrap_sass": "^5.0",
        "oomphinc/composer-installers-extender": "^2.0",
        "npm-asset/splidejs--splide": "^4.1",
        "drupal/block_visibility_conditions": "^2.1",
        "drupal/blockgroup": "^2.0",
        "drupal/block_classes": "^1.0",
        "drupal/fences": "^3.0",
        "drupal/image_widget_crop": "^3.0",
        "drupal/media_library_edit": "^3.0",
        "drupal/smart_date": "^4.2",
        "drupal/simple_gmap": "^4.0",
        "drupal/viewfield": "^3.0@beta",
        "drupal/linked_field": "^1.7",
        "drupal/fullcalendar_view": "^5.2",
        "drupal/pathologic": "^2.0@alpha",
        "drupal/token_filter": "^2.2",
        "drupal/views_bootstrap": "^5.4",
        "drupal/ckeditor_media_resize": "^1.0",
        "drupal/media_pdf_thumbnail": "^7.0",
        "drupal/frontend_editing": "^2.0@alpha",
        "drupal/ckeditor_link_styles": "^1.1",
        "drupal/eca": "^2.1",
        "drupal/bpmn_io": "^2.0",
        "drupal/draggableviews": "^2.1",
        "wikimedia/composer-merge-plugin": "^2.1",
        "drupal/paragraphs_edit": "^3.0",
        "drupal/media_file_delete": "^1.3",
        "drupal/media_entity_file_replace": "^1.3",
        "drupal/dropzonejs": "^2.11"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "extra": {
        "merge-plugin": {
            "include": [
                "web/modules/contrib/webform/composer.libraries.json",
                "web/modules/contrib/dropzonejs/composer.libraries.json",
                "web/modules/contrib/image_widget_crop/composer.libraries.json",
                "web/modules/contrib/moderation_dashboard/composer.libraries.json"
            ]
        },
        "installer-paths": {
            "web/core": ["type:drupal-core"],
            "web/libraries/{$name}": [
                "type:drupal-library",
                "type:bower-asset",
                "type:npm-asset"
            ],
            "web/modules/contrib/{$name}": ["type:drupal-module"],
            "web/profiles/contrib/{$name}": ["type:drupal-profile"],
            "web/themes/contrib/{$name}": ["type:drupal-theme"],
            "drush/contrib/{$name}": ["type:drupal-drush"]
        },
        "drupal-scaffold": {
            "locations": {
                "web-root": "web/"
            },
            "excludes": [
                "sites/development.services.yml",
                "sites/example.settings.local.php"
            ]
        },
        "installer-types": [
            "bower-asset",
            "npm-asset"
        ],
        "composer-exit-on-patch-failure": true,
        "enable-patching": true,
        "patchLevel": {
            "drupal/core": "-p2"
        },
        "patches": {
            "drupal/media_library_edit": {
                "3246687 - Don't unset the #submit callback": "https://git.drupalcode.org/project/media_library_edit/-/merge_requests/11.diff"
            },
            "drupal/image_widget_crop": {
                "3214365 - Crop widget not adjusting crop box when crop is applied": "https://www.drupal.org/files/issues/2021-06-09/crop_widget_not_adjusting_to_existing_crop-3214365-9.patch",
                "3119005 - When Drop Drupal 8.8 Support: Remove call to deprecated Libraries function libraries_detect()": "https://www.drupal.org/files/issues/2023-02-21/3119005-18.patch"
            },
            "drupal/paragraphs_edit": {
                "2914976 - Revisions log does not attribute author or timestamp correctly": "https://git.drupalcode.org/project/paragraphs_edit/-/merge_requests/14.diff"
            }
        }
    },
    "config": {
        "allow-plugins": {
            "drupal/core-project-message": false,
            "drupal/core-composer-scaffold": true,
            "cweagans/composer-patches": true,
            "composer/installers": true,
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "oomphinc/composer-installers-extender": true,
            "wikimedia/composer-merge-plugin": true
        }
    },
    "require-dev": {
        "drupal/devel": "^5.3"
    }
}

{#
/**
 * @file
 * Bootstrap Barrio's override to display a menu.
 *
 * Available variables:
 * - menu_name: The machine name of the menu.
 * - items: A nested list of menu items. Each menu item contains:
 *   - attributes: HTML attributes for the menu item.
 *   - below: The menu item child items.
 *   - title: The menu link title.
 *   - url: The menu link url, instance of \Drupal\Core\Url
 *   - localized_options: Menu link localized options.
 *   - is_expanded: TRUE if the link has visible children within the current
 *     menu tree.
 *   - is_collapsed: TRUE if the link has children within the current menu tree
 *     that are not currently visible.
 *   - in_active_trail: TRUE if the link is in the active trail.
 */
#}
{% import _self as menus %}

{#
  We call a macro which calls itself to render the full tree.
  @see http://twig.sensiolabs.org/doc/tags/macro.html
#}
{{ menus.menu_links(items, attributes, 0, has_offcanvas_menu, double_wide_offcanvas) }}

{% macro menu_links(items, attributes, menu_level, has_offcanvas_menu, double_wide_offcanvas) %}
  {% import _self as menus %}
  {% if items %}
    {% if menu_level == 0 %}
      {%
      set menu_classes = [
        'nav mt-2',
        has_offcanvas_menu and double_wide_offcanvas ? 'row row-cols-md-2',
        (not has_offcanvas_menu) or (not double_wide_offcanvas) ? 'navbar-nav'
      ]
      %}
      <ul{{ attributes.addClass(menu_classes)|without('id').setAttribute('role', 'menubar') }}>
    {% else %}
      {%
      set menu_classes = [
        'dropdown-menu',
        has_offcanvas_menu ? 'no-shadow',
      ]
      %}
      {% if not has_offcanvas_menu %}
        {# Open a dropdown wrapper element. #}
        {# IN essence, all this was doing was removing all the previous attributes and creating a new class.#}
        {# However it was also removing those attributed from the UL within, which breaks html validation, as the ID was being referenced by an 'aria-controls' (line 92) . #}
        {# <div{{ attributes.removeAttribute('id').removeAttribute('class').addClass('dropdown-menu-wrapper').removeAttribute('role') }}> #}
        <div class="dropdown-menu-wrapper">
          <ul{{ attributes.removeAttribute('class').addClass(menu_classes).setAttribute('role', 'menu') }}>
      {% else %}
        <ul{{ attributes.removeAttribute('class').addClass(menu_classes).setAttribute('role', 'menu') }}>
      {% endif %}
    {% endif %}
    {% for item in items %}
      {%
        set classes = [
          menu_level ? 'dropdown-item' : 'nav-item',
          item.is_expanded ? 'menu-item--expanded',
          item.is_collapsed ? 'menu-item--collapsed',
          item.in_active_trail ? 'active',
          item.below ? 'dropdown',
          (not menu_level) and (not has_offcanvas_menu) ? 'd-lg-flex',
          (not menu_level) and (not has_offcanvas_menu) ? 'align-items-stretch'
        ]
      %}
      {% set is_dropdown_without_children = (menu_level == 0 and item.url.getRouteName() == '<button>' and not item.below) %}
      {% if not is_dropdown_without_children %}
        <li{{ item.attributes.addClass(classes).setAttribute('role', 'menuitem') }}>
          {% set item_url_string = item.url.toString() %}
          {% set aria_id = (item.title ~ '-submenu-' ~ loop.index )|clean_id %}
          {%
            set link_classes = [
              'text-start',
              'd-lg-flex',
              'align-items-center',
              not menu_level ? 'nav-link',
              item.in_active_trail ? 'active',
              item.below ? 'w-100',
              item.url.getOption('attributes').class ? item.url.getOption('attributes').class | join(' '),
              'nav-link-' ~ (item_url_string ? item_url_string : 'nolink') | clean_class,
            ]
          %}
          {% if item.below %}
            {% set link_text %}
              <span class="menu-item-text">{{ item.title }}<i class="fa-solid fa-chevron-down ps-2 small" aria-hidden="true"></i></span>
            {% endset %}
            {{ link(link_text, item.url, {'class': link_classes, 'data-bs-toggle': 'dropdown', 'aria-expanded': 'false', 'aria-haspopup': 'true', 'aria-controls': aria_id }) }}
            {{ menus.menu_links(item.below, attributes.setAttribute('id', aria_id), menu_level + 1, has_offcanvas_menu, double_wide_offcanvas) }}
          {% else %}
            {% set link_text %}
              <span class="menu-item-text">{{ item.title }}</span>
            {% endset %}
            {{ link(link_text, item.url, {'class': link_classes}) }}
          {% endif %}
        </li>
      {% endif %}
    {% endfor %}
    </ul>
    {% if menu_level > 0 and not has_offcanvas_menu %}
      {# Close the drop-down menu wrapper element. #}
      </div>
    {% endif %}
  {% endif %}
{% endmacro %}
